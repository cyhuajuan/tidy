{
    "name": "@tidy/desktop",
    "version": "0.1.0",
    "private": true,
    "scripts": {
        "dev": "next dev -p 3200",
        "build": "next build",
        "start": "next start",
        "typecheck": "tsc --noEmit -p tsconfig.json",
        "lint": "pnpm --dir ../.. exec biome check apps/desktop",
        "format": "pnpm --dir ../.. exec biome format --write apps/desktop",
        "test": "vitest run"
    },
    "dependencies": {
        "next": "16.2.4",
        "react": "19.2.4",
        "react-dom": "19.2.4"
    },
    "devDependencies": {
        "@testing-library/dom": "^10.4.1",
        "@testing-library/jest-dom": "^6.9.1",
        "@testing-library/react": "^16.3.0",
        "@vitejs/plugin-react": "^5.1.0",
        "@tailwindcss/postcss": "^4",
        "@tauri-apps/cli": "^2.10.1",
        "@types/node": "^20",
        "@types/react": "^19",
        "@types/react-dom": "^19",
        "jsdom": "^27.0.1",
        "tailwindcss": "^4",
        "typescript": "5.9.3",
        "vite-tsconfig-paths": "^5.1.4",
        "vitest": "^4.0.7"
    }
}
